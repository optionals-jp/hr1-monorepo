-- ====================================================================
-- ASSERTS
-- ====================================================================

-- ====================================================================
-- ROLLBACK asserts: 全 crm_* policy が旧 helper を参照していること
-- ====================================================================
DO $$
DECLARE v_bad int;
BEGIN
  SELECT COUNT(*) INTO v_bad FROM pg_policies
  WHERE schemaname='public' AND tablename LIKE 'crm_%'
    AND (
      (qual IS NOT NULL AND qual::text ~ 'get_my_organization_ids\(\)')
      OR
      (with_check IS NOT NULL AND with_check::text ~ 'get_my_organization_ids\(\)')
    );
  IF v_bad <> 0 THEN
    RAISE EXCEPTION 'HR-28 rollback: % crm_* policies still reference SETOF helper', v_bad;
  END IF;
END $$;

COMMIT;
