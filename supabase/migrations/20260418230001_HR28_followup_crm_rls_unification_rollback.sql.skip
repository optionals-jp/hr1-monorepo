-- HR-28 follow-up ROLLBACK: CRM 20 tables 65 policies from public.get_my_organization_ids() back to public.get_my_organization_id()
--
-- このファイルは `.skip` 拡張子のため Supabase CLI/MCP の自動マイグレーション対象外。
-- 緊急ロールバックが必要な場合のみ `.skip` を外して apply_migration で適用する。
--
-- 方針: 20260418230000_HR28_followup_crm_rls_unification.sql と同じ in-place REPLACE を
-- 行うが、qual/with_check を旧 helper `public.get_my_organization_id()` (単数・LIMIT 1) に戻す。
-- マルチ組織所属ユーザーにバグが再発するが、緊急の一時退避用途に限り許容する。
--
-- 注意:
--   - 旧 helper `public.get_my_organization_id()` がまだ存在していること (未 DROP) が前提。
--   - rollback 後は必ず follow-up チケットで再修正し、`.skip` に戻すこと。

BEGIN;
SET LOCAL statement_timeout = '5min';

-- ====================================================================
-- (0) 旧 helper 関数の存在 assert (rollback 先として必要)
-- ====================================================================
DO $$
BEGIN
  IF NOT EXISTS (
    SELECT 1 FROM pg_proc p
    JOIN pg_namespace n ON n.oid = p.pronamespace
    WHERE n.nspname = 'public' AND p.proname = 'get_my_organization_id'
  ) THEN
    RAISE EXCEPTION 'HR-28 rollback: public.get_my_organization_id() (singular) is missing. Aborting — rollback target helper not available.';
  END IF;
END $$;

-- ====================================================================
-- (1) crm_activities (per-cmd S/I/U/D, authenticated)
-- ====================================================================
DROP POLICY IF EXISTS crm_activities_select ON public.crm_activities;
CREATE POLICY crm_activities_select ON public.crm_activities
  FOR SELECT TO authenticated
  USING (organization_id = public.get_my_organization_id());

DROP POLICY IF EXISTS crm_activities_insert ON public.crm_activities;
CREATE POLICY crm_activities_insert ON public.crm_activities
  FOR INSERT TO authenticated
  WITH CHECK (organization_id = public.get_my_organization_id());

DROP POLICY IF EXISTS crm_activities_update ON public.crm_activities;
CREATE POLICY crm_activities_update ON public.crm_activities
  FOR UPDATE TO authenticated
  USING (organization_id = public.get_my_organization_id())
  WITH CHECK (organization_id = public.get_my_organization_id());

DROP POLICY IF EXISTS crm_activities_delete ON public.crm_activities;
CREATE POLICY crm_activities_delete ON public.crm_activities
  FOR DELETE TO authenticated
  USING (organization_id = public.get_my_organization_id());

