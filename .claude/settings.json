{
  "hooks": {
    "postToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": []
      }
    ],
    "preCompact": [],
    "stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd hr1-console && npm run format:check 2>&1 | tail -5"
          },
          {
            "type": "command",
            "command": "cd hr1-console && npm run lint 2>&1 | tail -10"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(git diff:*)",
      "WebFetch(domain:accounts-assets.freee.co.jp)",
      "mcp__claude_ai_Supabase__list_edge_functions",
      "Bash(supabase init:*)",
      "Bash(supabase link:*)"
    ],
    "additionalDirectories": []
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "supabase@claude-plugins-official": true
  }
}
