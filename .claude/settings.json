{
  "hooks": {
    "postToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": []
      }
    ],
    "preCompact": [],
    "stop": [
      {
        "matcher": "",
        "hooks": [
          {
